{
    "name": "padosoft/laravel-ai-price-intelligence-admin",
    "description": "Web admin panel (React 19 + Vite + Tailwind 4) for padosoft/laravel-ai-price-intelligence — competitor price & product intelligence.",
    "keywords": ["laravel", "admin", "price-intelligence", "competitor-monitoring", "react", "ecommerce"],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Lorenzo Padovani",
            "email": "lorenzo.padovani@padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "laravel/sanctum": "^4.0",
        "padosoft/laravel-ai-price-intelligence": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.18",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\PriceIntelligenceAdmin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\PriceIntelligenceAdmin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\PriceIntelligenceAdmin\\PriceIntelligenceAdminServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
